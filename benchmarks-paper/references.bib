%   - Upstream sources (MedMCQA, MedQA-USMLE, AfriMed-QA, Kenya Clinical
%     Vignettes, WHB stumps, HealthBench)
%   - Classifier and judge models (Qwen3 family, vLLM, guided_json)
%   - Benchmark construction methodology (BEIR, TREC pooling, UMBRELA,
%     RTEB English, DeCE, Saracevic relevance hierarchy, G-Eval)
%   - Retrievers (BM25, MedCPT, Octen-Embedding-8B, voyage-4, BGE-reranker,
%     LateOn)
%   - Datasheet / responsible-release frameworks

% ===== Companion paper (the deployment / system paper) =====
% Name is in Chinese order (family name Ren, given name Yi). Double braces keep
% "Ren Yi" as one unit so it cites as "[Ren Yi 2026]" in native order. When the
% system paper is on arXiv, add: eprint = {XXXX.XXXXX}, archivePrefix = {arXiv},
% primaryClass = {cs.CL}.
@misc{ren2026mamai,
  author       = {{Ren Yi}},
  title        = {{MAM-AI}: An On-Device Medical Retrieval-Augmented Generation System for Nurses and Midwives in Zanzibar},
  year         = {2026},
  note         = {Companion paper; arXiv preprint forthcoming}
}

